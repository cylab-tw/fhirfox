{
	"name": "fhirfox-generator",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"dataset",
		"converter",
		"frontend"
	],
	"scripts": {
		"postinstall": "patch-package",
		"build": "npm run build --workspace dataset && npm run build --workspace converter && npm run build --workspace frontend",
		"dataset:check": "npm run check --workspace dataset",
		"dataset:doctor": "npm run doctor --workspace dataset",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"lint": "prettier --check . && eslint .",
		"format": "prettier . --write"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"patch-package": "^8.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2"
	}
}
