{
	"name": "fhirfox-generator",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "tsx watch server.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/server.js",
		"typecheck": "tsc --noEmit",
		"format": "prettier . --write",
		"lint": "prettier --check . && eslint ."
	},
	"dependencies": {
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1"
	}
}
