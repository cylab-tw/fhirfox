# Build-time deployment mode.
FHIRFOX_DEPLOYMENT_MODE=static

# Base path when deploying under a subdirectory.
FHIRFOX_BASE_PATH=/

# Vite dev-server proxy target for backend mode.
FHIRFOX_BACKEND_PROXY_TARGET=http://127.0.0.1:8787

# Used when building or running in backend deployment mode.
FHIRFOX_BACKEND_API_BASE_URL=/api
FHIRFOX_DEFAULT_SEED=1234
